{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "module": "esnext",
    "target": "es2017",
    "lib": ["es2017", "dom"],
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "*": ["*"]
    }
  },
  "include": [
    "frontend/js/**/*.js",
    "frontend/*.html"
, "frontend/js/scanner.js"  ],
  "exclude": [
    "node_modules",
    "backend",
    "cloudflare-worker",
    "docs"
  ]
}
